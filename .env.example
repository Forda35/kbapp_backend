# Base de données PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/kbapp_db"

# JWT Secret (changez ceci par une clé aléatoire longue)
JWT_SECRET="votre_jwt_secret_tres_long_et_securise_ici"

# Configuration Email (SMTP)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="votre_email@gmail.com"
EMAIL_PASS="votre_mot_de_passe_application_gmail"
EMAIL_FROM="KBApp <votre_email@gmail.com>"

# URL de l'application (pour les liens de vérification)
APP_URL="https://votre-domaine.com"
FRONTEND_URL="https://votre-domaine.com"

# Code marchand Mobile Money
# ===========================
# Mettez votre code marchand MVola ici :
MVOLA_MERCHANT_CODE="VOTRE_CODE_MARCHAND_MVOLA"
# Code marchand Orange Money :
ORANGE_MONEY_MERCHANT_CODE="VOTRE_CODE_MARCHAND_ORANGE"
# Code marchand Airtel Money :
AIRTEL_MONEY_MERCHANT_CODE="VOTRE_CODE_MARCHAND_AIRTEL"

# Port du serveur
PORT=5000
